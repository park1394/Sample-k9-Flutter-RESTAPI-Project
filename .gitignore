# ============================================================
# 루트 .gitignore — 실제 소스 코드만 Git 추적 대상에 포함
# ============================================================

# ----- OS / IDE -----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.iml

# ----- 도구 상태 / 세션 캐시 -----
.omc/
**/.omc/

# ============================================================
# Spring Boot / Gradle (백엔드)
# ============================================================
**/.gradle/
**/build/
**/bin/
**/out/
*.class
*.log
*.war
*.jar
!**/gradle/wrapper/gradle-wrapper.jar
hs_err_pid*
replay_pid*

# ============================================================
# Flutter / Dart (프론트엔드)
# ============================================================
Flutter-Front/.dart_tool/
Flutter-Front/.flutter-plugins
Flutter-Front/.flutter-plugins-dependencies
Flutter-Front/.packages
Flutter-Front/.pub-cache/
Flutter-Front/.pub/
Flutter-Front/build/
Flutter-Front/android/.gradle/
Flutter-Front/android/local.properties
Flutter-Front/android/key.properties
Flutter-Front/ios/Pods/
Flutter-Front/ios/.symlinks/
Flutter-Front/ios/Flutter/Flutter.framework
Flutter-Front/ios/Flutter/Flutter.podspec
Flutter-Front/ios/Flutter/App.framework
Flutter-Front/ios/Flutter/flutter_assets/
Flutter-Front/ios/Flutter/Generated.xcconfig
Flutter-Front/ios/Flutter/ephemeral/
Flutter-Front/ios/Runner/GeneratedPluginRegistrant.*

# ============================================================
# Flask (파이썬) — 사용 중일 경우
# ============================================================
Flask-Back/__pycache__/
Flask-Back/**/__pycache__/
Flask-Back/venv/
Flask-Back/.venv/
*.pyc
*.pyo

# ============================================================
# 환경 변수 / 시크릿
# ============================================================
.env
.env.local
*.local
